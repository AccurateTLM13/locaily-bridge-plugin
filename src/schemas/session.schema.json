{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "locaily.session.v1",
  "title": "LocAIly Session",
  "description": "Records a single OpenCode agent work session.",
  "type": "object",
  "required": ["sessionId", "projectId", "repository", "branch", "startedAt", "status"],
  "properties": {
    "sessionId": {
      "type": "string",
      "description": "Unique session identifier.",
      "pattern": "^ses_[0-9]{4}_[0-9]{2}_[0-9]{2}_[0-9]{3}$",
      "examples": ["ses_2026_06_28_001"]
    },
    "projectId": {
      "type": "string",
      "description": "The project this session belongs to."
    },
    "objectiveId": {
      "type": "string",
      "description": "The objective this session is working on."
    },
    "repository": {
      "type": "string",
      "description": "Absolute path to the repository."
    },
    "branch": {
      "type": "string",
      "description": "Git branch at session start."
    },
    "startedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the session started."
    },
    "endedAt": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO 8601 timestamp when the session ended."
    },
    "status": {
      "type": "string",
      "enum": ["active", "completed", "blocked", "paused", "failed"],
      "description": "Current status of the session."
    },
    "eventCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of events recorded in this session."
    }
  },
  "additionalProperties": false
}
