{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "locaily.handoff.v1",
  "title": "LocAIly Handoff",
  "description": "Structured output produced at the end of a session.",
  "type": "object",
  "required": ["sessionId", "projectId", "objectiveId", "status", "summary", "changedFiles", "blockers"],
  "properties": {
    "sessionId": {
      "type": "string",
      "description": "Must match the active session ID."
    },
    "projectId": {
      "type": "string",
      "description": "Must match the resolved project ID."
    },
    "objectiveId": {
      "type": "string",
      "description": "Must match the active objective ID."
    },
    "status": {
      "type": "string",
      "enum": ["completed", "blocked", "paused", "failed"],
      "description": "Outcome status of the session."
    },
    "summary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "1-3 sentence summary of work completed."
    },
    "changedFiles": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 0,
      "description": "List of files changed during the session."
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "status"],
        "properties": {
          "command": { "type": "string" },
          "status": { "type": "string", "enum": ["passed", "failed", "skipped"] }
        },
        "additionalProperties": false
      },
      "description": "Validation commands run and their results."
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["decision", "reason"],
        "properties": {
          "decision": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      },
      "description": "Design decisions made during the session."
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "blocker": { "type": "string" },
          "impact": { "type": "string" }
        },
        "required": ["blocker"],
        "additionalProperties": false
      },
      "description": "Blockers encountered. Empty array if none."
    },
    "nextRecommendedAction": {
      "type": "string",
      "description": "Suggested next step for the next agent or session."
    }
  },
  "additionalProperties": false
}
